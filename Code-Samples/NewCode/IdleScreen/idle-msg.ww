        .word 0
        .word 0o110263   ; /* 5 */
        .word 0
        .word 0o114307   ; /* R */
        .word 0
        .word 0o002014   ; /* 1 */
        .word 0
        .word 0o000174   ; /* J */
        .word 0
        .word 0o000017   ; /* 7 */
        .word 0
        .word 0o010714   ; /* N */
        .word 0
        .word 0o012000   ; /* ( */
        .word 0
