
; Alpha Character display code
; Guy Fedorkow
; Nov 21, 2025; Mar 7, 2026
; This program displays a simple text message on the WW CRT display
; The text of the message is one of eight messages, selected by the low three bits
; of FF Register 2

; Modified Apr 19, 2026 to position the message in the center of the screen
; Modified Apr 19, 2026 to make descenders on g, j, p, y, q

; constants for SI graphics instruction
            .pp scope_vector, 0o1677   ; draw a vector on all scopes
            .pp scope_point, 0o0677   ; draw a point on all scopes


; Alias for Flip-Flop-Register
            .pp FFReg02, 02
            .pp FFReset, 0o10     ; SI instruction to copy presets into the FF Registers


            .org 0
zero:       .word 0
one:        .word 1


            .org 0o40

main:       sp init                 ; call the init subroutine
            sp refresh_loop         ; branch to main display refresh loop
            
msgtab_ptr: .word msgtab0            
msgtab0:    .word msg0
msgtab1:    .word msg1
msgtab2:    .word msg2
msgtab3:    .word msg3
msgtab4:    .word msg4
msgtab5:    .word msg5
msgtab6:    .word msg6
msgtab7:    .word msg7


; display a string on the CRT, lengthening it by one character until it's full length, then
; reset the count and start again.  
refresh_loop: 
            si FFReset      ; copy preset switches into FF Regs
            ca FFReg02      ; figure out what message to print
            md const_7      ; mask to three bits
            ts msg_num
            ad msgtab_ptr   ; this is the address into the message table
            td rl_ld_msgp
rl_ld_msgp: ca 0            ; fetch the message pointer from the table
            ts msgp         ; store a pointer to the start of the string to print.
            
            ca zero         ; initialize the length of the string to zero
            ts msg_strlen
msg_loop:
            ca msg_strlen
            ts ds_arglen
            ; start the string near the top left edge of the screen
            ca c_msg_x_pos
            ts ds_argx
            ca c_msg_y_pos     
            su char_yspacing    ; character origin is the lower-left corner, so make sure it doesn't overflow Y axis
            ts ds_argy
            ca msgp
            sp draw_str         ; this routine prints the string until either a negative character terminator OR the count is exhausted
            ;si 0

            ; on each pass, make the string longer by two, up to the max length
            ao msg_strlen
            ao msg_strlen
            su msg_maxlen
            cp msg_loop

            ca zero
            ts msg_strlen
            sp refresh_loop

loop_count:  ; used only in top-level routines for drawing the game board
          .word 0

init:     ta init_ret
init_ret: sp 0    


msg_maxlen:  .word 0o200
msg_strlen:  .word 0     ; we lengthen the string by one char until it reaches the end and we've counted to msg_maxlen
msg_num:     .word 0     ; this should be an offset into the table of messages to select just one

;msg0:       .flexl "WHIRLWIND\nEMULATOR\nabcdefghijklm\nnopqrstuvwxyz", -1  ; remember that the converted string will count shift-up/down as characters

msg0:       .flexl "WHIRLWIND\nEMULATOR\nVibrating\n String", -1  
msg1:       .flexl "WHIRLWIND\nEMULATOR\nBounce\n w/ Hole", -1  ; remember that the converted string will count shift-up/down as characters
msg2:       .flexl "WHIRLWIND\nEMULATOR\n34-word\n Bounce", -1
msg3:       .flexl "WHIRLWIND\nEMULATOR\nBlack\njack", -1  
msg4:       .flexl "WHIRLWIND\nEMULATOR\nTic Tac Toe", -1  
msg5:       .flexl "WHIRLWIND\nEMULATOR\nRocket\nTrajectory", -1  
msg6:       .flexl "WHIRLWIND\nEMULATOR\nMad Game", -1  
msg7:       .flexl "WHIRLWIND\nEMULATOR\nunused\nprogram 7", -1  



; ****************************************


; Constants
const_2:  .word 2
const_3:  .word 3
const_4:  .word 4
const_6:  .word 6
const_7:  .word 7
const_8:  .word 8
const_9:  .word 9
const_10: .word 10
const_11: .word 11    ; loop counter for 12 iterations
const_12: .word 12

; constants
c_15:           .word 15
c_32:           .word 32
c_msg_x_pos:    .word -550 * 32      ; coord of left edge of message
c_msg_y_pos:    .word 350 * 32       ; coord of top edge of message

; these two constants give the delta values to draw a "maximum short vector"
horiz_line_seg:    .word 0o174 * 0o400   ; +32 in the top half of the word
vert_line_seg:     .word 0o174            ; +32 in the bottom half of the word
diag_up_right_seg: .word 0o174 * 0o400 + 0o174
diag_dn_left_seg:  .word 0o200 * 0o400 + 0o200
diag_dn_right_seg: .word 0o174 * 0o400 + 0o200
diag_up_left_seg:  .word 0o200 * 0o400 + 0o174


; ---------------------------------------

panic_stop:
        ca 0
        .print "panic stop"
        si 0



; 
;=====================================================================================

; /* 16-segment character generator, originally in Core Memory Clock
;  *
;  * Guy Fedorkow, Feb 22, 2025
;  *  originally for Arduino Mega
;  *
;  */
;

ut_maxlen:  .word 0o60
ut_strlen:  .word 0

msgp:       .word unit_msg 
unit_msg:   .flexl "WHIRLWIND\nEMULATOR\nabcdefghijklmnopqrstuvwxyz", -1  ; remember that the converted string will count shift-up/down as characters
            .word 0



; -----------------------------------------
; draw a character string on the CRT
; AC contains a pointer to the string, terminated by the first negative 'character'
; ds_argx and ds_argy give the initial (x, y) location
; ds_arglen gives a maximum character count.  (i.e., the string terminates either when 
;       the count is exhausted or a negative character is encountered)
draw_str:
            ta ds_ret
            td ds_lcl_charp      ; save the character pointer passed in the ACC
ds_loop:
            ca ds_argx
            ts d16c_argx
            ca ds_argy
            ts d16c_argy
            ca ds_lcl_charp     ; walk the string from start to finish
            td ds_get_char
ds_get_char:
            ca 0                ; fetch the next character in the string
            sp draw_16seg_char    ; actually draw the character!

            ao ds_lcl_charp       ; prepare for next char in loop
            td ds_test_str_end
ds_test_str_end:  ; bail out if the next char is negative, or if the loop count is exhausted
            ca 0
            cp ds_ret       ; test for a negative number as the marker for the string end; branch out if done
            ca ds_arglen    ; ; decrement the length count
            su one
            ts ds_arglen
            cp ds_ret
            
            ; I moved the x and y auto-increment into the character-drawing routine draw_16seg_char
            sp ds_loop

ds_ret:
            sp 0

ds_lcl_charp: .word 0    ; pointer to the next character to display
ds_argx:    .word 0
ds_argy:    .word 0
ds_arglen:  .word 10

; ---------------------------


c_newline: .word 0o51              ; character value for Carriage Return
c_upper:   .word 0o71              ; character value for Shift Upper
c_lower:   .word 0o75              ; character value for Shift Lower

; Draw a Flexo character passed in to this routine in the ACC
; First, find the segment map for a given character.  Input is a Flexo-coded character.
; The routine returns a 16-bit int where each bit represents one stroke in the character.  If the
; bit is one, draw the stroke; if not, don't draw.
; Character position is given by the args d16c_argx, d16c_argy.
lcl_ds16_char:  .word 0   ; local storage for the character to be displayed
draw_16seg_char:
        ta d16c_ret
        ts lcl_ds16_char    ; save the incoming character to be printed

        su c_upper          ; test to see if we've got a "Shift Upper" character
        dm 0
        dm 0                ; negative zero if acc == c_upper
        cp ds16_shift_to_upper   ; adjust the current Case, then exit

        ca lcl_ds16_char
        su c_lower
        dm 0
        dm 0                ; negative zero if acc == c_lower
        cp ds16_shift_to_lower   ; adjust the current Case, then exit

        ca lcl_ds16_char
        su c_newline
        dm 0
        dm 0                ; negative zero if acc == c_newline
        cp ds16_newline   ; execute a newline, then exit

        ; if it's not a shift character, just keep going and print with the current case
        ca lcl_ds16_char        ; re-fetch the input character
ds16_offset:
        slh 1                   ; multiply by two; two words per table entry
        ad SixteenSegmentFlexop     ; add the table start addr to the offset in ACC
;        .print "draw_16seg_char:  char=%ao. d16c_argx=%o, d16c_argy=%o", d16c_argx, d16c_argy
        td d16c_rd
        ad one
        td d16c_drd
d16c_rd:
        ca 0                        ; fetch the bit map
        ts d16c_lcl_seg_map
d16c_drd:
        ca 0                        ; fetch the bit map
        ts d16c_lcl_descender

        ; draw the sixteen segments, starting with the most significant bit
        cs c_15                     ; prep for 16 times around the loop
        ts d16c_lcl_loop_cnt
        ca seg_tab_endp             ; walk the segment table back to front
        td d16c_read_seg_tabx       ; first table entry
;        td tmp_tabx
        ad one
        td d16c_read_seg_taby       ; second table entry
;        td tmp_taby
        ad one
        td d16c_read_seg_tabdxy     ; third table entry

; I've commented out a bit of debug code here to draw dots at each of the junction points in the
; 16-segment figure.  Use this to verify that the line segments are the right length...
d16s_loop:
        ; this strip draws dots at the intersection points
;        ca 0  ; no op
;tmp_taby:
;        ca 0
;        si scope_point
;tmp_tabx:
;        ca 0
;        rc 0
        ; end of debug hack
        ca d16c_lcl_seg_map
        cp d16c_draw_seg            ; branch if most significant bit is on

d16s_loop_continue:
        ca d16c_lcl_seg_map
        clc 1                       ; shift AC left by one bit
        ts d16c_lcl_seg_map
        ca d16c_read_seg_tabx
        su const_3
        td d16c_read_seg_tabx
;        td tmp_tabx
        ca d16c_read_seg_taby
        su const_3
        td d16c_read_seg_taby
;        td tmp_taby
        ca d16c_read_seg_tabdxy
        su const_3
        td d16c_read_seg_tabdxy
        ao d16c_lcl_loop_cnt
        cp d16s_loop

        ; fall through here when the count is exhausted
        ; advance x position to the next character
        ca ds_argx
        ad char_xspacing
        ts ds_argx
        sp d16c_ret                 ; bail out when count exhausted

; on entry to this code block, the three entries in the segment table should give relative positions:
;   _tab1 = X pos'n
;   _tab2 = Y pos'n
;   _tab3 = XY Delta vector
d16c_draw_seg:                      ; branch here if we're doing a segment, then return to the loop
        ; the SI uses the AC to set Y coord
d16c_read_seg_taby:
        ca 0               ; overwritten by the table y value
        ad d16c_lcl_descender   ; if the character has a descender, reduce the y value
        ad d16c_argy       ; add the current screen y value
        si scope_vector    ; initialize vector gen with the y-coord in ACC

        ; the RC uses AC to set X coord and mem address for the vector length
d16c_read_seg_tabx:
        ca 0
        ad d16c_argx
d16c_read_seg_tabdxy:
        rc 0
        sp d16s_loop_continue

ds16_shift_to_upper:
        ca SixteenSegmentUpperp
        ts SixteenSegmentFlexop    ; shift pointer to Upper Case table & exit
        sp d16c_ret

ds16_shift_to_lower:
        ca SixteenSegmentLowerp
        ts SixteenSegmentFlexop    ; shift pointer to Lower Case table & exit
        sp d16c_ret

ds16_newline:
        ca c_msg_x_pos
        ts ds_argx
        ca ds_argy     
        su char_yspacing 
        ts ds_argy

        sp d16c_ret


d16c_ret:   ;; Return from draw_16seg_char
        sp 0

d16c_argx:
        .word 0
d16c_argy:
        .word 0
d16c_lcl_seg_map:
        .word 0
d16c_lcl_descender:
        .word 0
d16c_lcl_loop_cnt:
        .word 0
;


; ---------------------------
; The following table, indexed by ASCII character, gives a bit map of which of the 16
; segments should be lit for each symbol.
; This pointer gets overwritten by one of the following two depending on the last Shift character.
; Apr 19, 2026 - I modified the table to add a second word per character to give an extra y-offset to
; each character, to accommodate lower case descenders.
SixteenSegmentFlexop:
            .word flexo_lcase       ; flexowriter defaults to lower case
;DescenderFlexop:
;            .word descender_lcase       ; flexowriter defaults to lower case
SixteenSegmentUpperp:
            .word flexo_ucase
;DescenderUpperp:
;            .word descender_ucase 
SixteenSegmentLowerp:
            .word flexo_lcase
;DescenderLowerp:
;            .word descender_lcase

flexo_ucase:
        .word 0o125074   ; /* # */
        .word 0
        .word 0o125074   ; /* # */
        .word 0
        .word 0o100363   ; /* E */
        .word 0
        .word 0o104377   ; /* 8 */
        .word 0
        .word 0o125074   ; /* # */
        .word 0
        .word 0o000060   ; /* _ */
        .word 0
        .word 0o104317   ; /* A */
        .word 0
