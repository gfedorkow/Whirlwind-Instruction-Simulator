@0751:134000                       dm 0
@0752:134000                       dm 0                     ; negative zero if acc == c_upper
@0753:071036                       cp ds16_shift_to_upper   ; adjust the current Case, then exit

@0754:100745                       ca lcl_ds16_char
@0755:114744                       su c_lower
@0756:134000                       dm 0
@0757:134000                       dm 0                     ; negative zero if acc == c_lower
