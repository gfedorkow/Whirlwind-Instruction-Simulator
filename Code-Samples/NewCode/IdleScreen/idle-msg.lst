@0774:134000                       dm 0
@0775:134000                       dm 0                     ; negative zero if acc == c_upper
@0776:071067                       cp ds16_shift_to_upper   ; adjust the current Case, then exit

@0777:100770                       ca lcl_ds16_char
@1000:114767                       su c_lower
@1001:134000                       dm 0
@1002:134000                       dm 0                     ; negative zero if acc == c_lower
