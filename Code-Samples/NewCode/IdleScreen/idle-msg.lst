@0721:044722                       td ds_get_char
                      ds_get_char:
@0722:100000                       ca 0                     ; fetch the next character in the string @@WrittenBy a0721
@0723:074746                       sp draw_16seg_char       ; actually draw the character!

@0724:130736                       ao ds_lcl_charp          ; prepare for next char in loop
@0725:044726                       td ds_test_str_end
