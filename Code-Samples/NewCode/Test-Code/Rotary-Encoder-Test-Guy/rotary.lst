                              ; Test code for MicroWhirlwind Rotary Encoder
                              ; g fedorkow, Jul 9, 2026 at HNF

                              ; move a single bit back and forth across FF2 and FF3 light registers
                              ; as the rotary knob is turned up and down.  The motion should be smooth,
                              ; and simply stop once the upper and lower ends of the range is hit.


                              .dbwgt Encoder, incr = 1, min = 1, max = 31, fmt = "%d"
                              .pp c_zero, 0
                              .pp c_one, 1

                              .pp scope_point, 0o0677  ; draw a point on all scopes
                              .pp scope_vector, 0o1677 ; draw a vector on all scopes

                              .org 2
@0002:000000             FF2: .word 0                  ; @@WrittenBy a0067 a0076
@0003:000000             FF3: .word 0                  ; @@WrittenBy a0065 a0100

                              .org 0o40
                        main:
                              ; experiment
@0040:100000                  ca c_zero
@0041:134000                  dm 0
@0042:030110                  sd c_nzero
@0043:044064                  td hi_shft
                              ; back to work

@0044:000677                  si scope_point
@0045:100105                  ca const_15
@0046:040166                  ts Encoder

                        loop:
@0047:074111                  sp draw_lines            ; @@JumpedToBy a0053 a0070 a0101
@0050:100166                  ca Encoder
@0051:134167                  dm lastval
@0052:134000                  dm 0
@0053:070047                  cp loop

@0054:100166                  ca Encoder
@0055:110001                  ad c_one
@0056:114106                  su const_16
@0057:070071                  cp lower_ff

                    upper_ff:
@0060:100166                  ca Encoder
@0061:174105                  md const_15              ; keep the lower four bits
@0062:044064                  td hi_shft
@0063:100001                  ca c_one
@0064:170000         hi_shft: clc 0                    ; @@WrittenBy a0043 a0062
@0065:040003                  ts FF3
@0066:100000                  ca c_zero
@0067:040002                  ts FF2

@0070:074047                  sp loop

                    lower_ff:
@0071:100166                  ca Encoder               ; @@JumpedToBy a0057
@0072:174105                  md const_15
@0073:044075                  td lo_shft
@0074:100001                  ca c_one
@0075:170000         lo_shft: clc 0                    ; @@WrittenBy a0073
@0076:040002                  ts FF2
@0077:100000                  ca c_zero
@0100:040003                  ts FF3
@0101:074047                  sp loop

@0102:000002         const_2: .word 2                  ; @@ReadBy a0114
@0103:000010         const_8: .word 8                  ; @@ReadBy a0127 a0144 a0150
