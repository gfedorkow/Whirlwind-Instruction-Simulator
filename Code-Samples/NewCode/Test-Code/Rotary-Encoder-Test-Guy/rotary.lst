@0107:100000       const_msb: .word 0o100000
@0110:177777         c_nzero: .word 0o177777           ; @@ReadBy a0042

                              ; pilfered from tic tac toe
                  draw_lines:
@0111:050124                  ta dl_ret                ; @@JumpedToBy a0047
@0112:100000                  ca c_zero
@0113:040161                  ts y_arg
@0114:100102                  ca const_2
@0115:040162                  ts x_arg
@0116:104104                  cs const_11
@0117:040163                  ts n_segments            ; segment count should be negative, ie, we will incr the value until positive
@0120:074142                  sp draw_x_line

@0121:100166                  ca Encoder
@0122:040162                  ts x_arg
@0123:074125                  sp draw_y_seg
