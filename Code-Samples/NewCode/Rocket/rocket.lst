                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0341:050425                    ta SQRET

@0342:040426                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0343:161001                    srh 1                    ; AC = S/2
@0344:110430                    ad SQHALF                ; AC = S/2 + 0.5
@0345:040427                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0346:100426                    ca SQARG
@0347:150427                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0350:155016                    slh 14                   ; AC = quotient from BR
@0351:040431                    ts sqtmp
@0352:100427                    ca SQEST                 ; AC = S/x + x
@0353:161001                    srh 1                    ; AC = (S/x + x) / 2
@0354:110431                    ad sqtmp
@0355:040427                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0356:100426                    ca SQARG
@0357:150427                    dv SQEST
@0360:155016                    slh 14
@0361:040431                    ts sqtmp
@0362:100427                    ca SQEST
@0363:161001                    srh 1
@0364:110431                    ad sqtmp
@0365:040427                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0366:100426                    ca SQARG
@0367:150427                    dv SQEST
@0370:155016                    slh 14
@0371:040431                    ts sqtmp
@0372:100427                    ca SQEST
@0373:161001                    srh 1
@0374:110431                    ad sqtmp
@0375:040427                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0376:100426                    ca SQARG
@0377:150427                    dv SQEST
@0400:155016                    slh 14
@0401:040431                    ts sqtmp
@0402:100427                    ca SQEST
@0403:161001                    srh 1
@0404:110431                    ad sqtmp
@0405:040427                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0406:100426                    ca SQARG
@0407:150427                    dv SQEST
@0410:155016                    slh 14
@0411:040431                    ts sqtmp
@0412:100427                    ca SQEST
@0413:161001                    srh 1
@0414:110431                    ad sqtmp
@0415:040427                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0416:100426                    ca SQARG
@0417:150427                    dv SQEST
@0420:155016                    slh 14
@0421:040431                    ts sqtmp
@0422:100427                    ca SQEST
@0423:161001                    srh 1
@0424:110431                    ad sqtmp

@0425:074000             SQRET: sp 0                     ; @@WrittenBy a0341

                                ; =============================================================
                                ; DATA
                                ; =============================================================
@0426:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0342 ReadBy a0346 a0356 a0366 a0376 a0406 a0416
@0427:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0345 a0355 a0365 a0375 a0405 a0415 ReadBy a0347 a0352 a0357 a0362 a0367 a0372 a0377 a0402 a0407 a0412 a0417 a0422
@0430:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0344
@0431:000000             sqtmp: .word 0                  ; @@WrittenBy a0351 a0361 a0371 a0401 a0411 a0421 ReadBy a0354 a0364 a0374 a0404 a0414 a0424

