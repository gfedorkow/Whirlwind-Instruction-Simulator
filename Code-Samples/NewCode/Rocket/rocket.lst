                                ; DATA
                                ; =============================================================
@0426:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0341 ReadBy a0345 a0355 a0365 a0375 a0405 a0415
@0427:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0344 a0354 a0364 a0374 a0404 a0414 ReadBy a0346 a0351 a0356 a0361 a0366 a0371 a0376 a0401 a0406 a0411 a0416 a0421
@0430:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0343
@0431:000000             sqtmp: .word 0                  ; @@WrittenBy a0350 a0360 a0370 a0400 a0410 a0420 ReadBy a0353 a0363 a0373 a0403 a0413 a0423

