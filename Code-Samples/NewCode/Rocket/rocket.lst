                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ; [contrary to Claude's assertion, this sqrt approximation is off by
                                ; much more than one LSB; There's a big correction factor at the end to
                                ; prevent overflows elsewhere]
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0342:050427                    ta SQRET                 ; @@JumpedToBy a0113

@0343:040430                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0344:161001                    srh 1                    ; AC = S/2
@0345:110432                    ad SQHALF                ; AC = S/2 + 0.5
@0346:040431                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0347:100430                    ca SQARG
@0350:150431                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0351:155016                    slh 14                   ; AC = quotient from BR
@0352:040433                    ts sqtmp
@0353:100431                    ca SQEST                 ; AC = S/x + x
@0354:161001                    srh 1                    ; AC = (S/x + x) / 2
@0355:110433                    ad sqtmp
@0356:040431                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0357:100430                    ca SQARG
@0360:150431                    dv SQEST
@0361:155016                    slh 14
@0362:040433                    ts sqtmp
@0363:100431                    ca SQEST
@0364:161001                    srh 1
@0365:110433                    ad sqtmp
@0366:040431                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0367:100430                    ca SQARG
@0370:150431                    dv SQEST
@0371:155016                    slh 14
@0372:040433                    ts sqtmp
@0373:100431                    ca SQEST
@0374:161001                    srh 1
@0375:110433                    ad sqtmp
@0376:040431                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0377:100430                    ca SQARG
@0400:150431                    dv SQEST
@0401:155016                    slh 14
@0402:040433                    ts sqtmp
@0403:100431                    ca SQEST
@0404:161001                    srh 1
@0405:110433                    ad sqtmp
@0406:040431                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0407:100430                    ca SQARG
@0410:150431                    dv SQEST
@0411:155016                    slh 14
@0412:040433                    ts sqtmp
@0413:100431                    ca SQEST
@0414:161001                    srh 1
@0415:110433                    ad sqtmp
@0416:040431                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0417:100430                    ca SQARG
@0420:150431                    dv SQEST
@0421:155016                    slh 14
@0422:040433                    ts sqtmp
@0423:100431                    ca SQEST
@0424:161001                    srh 1
@0425:110433                    ad sqtmp
@0426:110246                    ad const_15              ; ensure the result is greater or equal to the actual sqrt

@0427:074000             SQRET: sp 0                     ; @@WrittenBy a0342

