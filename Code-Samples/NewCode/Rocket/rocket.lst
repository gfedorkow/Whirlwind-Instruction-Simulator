                                ; DATA
                                ; =============================================================
@0433:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0346 ReadBy a0352 a0362 a0372 a0402 a0412 a0422
@0434:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0351 a0361 a0371 a0401 a0411 a0421 ReadBy a0353 a0356 a0363 a0366 a0373 a0376 a0403 a0406 a0413 a0416 a0423 a0426
@0435:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0350
@0436:000000             sqtmp: .word 0                  ; @@WrittenBy a0355 a0365 a0375 a0405 a0415 a0425 ReadBy a0360 a0370 a0400 a0410 a0420 a0430

