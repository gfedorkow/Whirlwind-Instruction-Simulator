                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ; [contrary to Claude's assertion, this sqrt approximation is off by
                                ; much more than one LSB; There's a big correction factor at the end to
                                ; prevent overflows elsewhere]
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0351:050436                    ta SQRET                 ; @@JumpedToBy a0122

@0352:040437                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0353:161001                    srh 1                    ; AC = S/2
@0354:110441                    ad SQHALF                ; AC = S/2 + 0.5
@0355:040440                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0356:100437                    ca SQARG
@0357:150440                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0360:155016                    slh 14                   ; AC = quotient from BR
@0361:040442                    ts sqtmp
@0362:100440                    ca SQEST                 ; AC = S/x + x
@0363:161001                    srh 1                    ; AC = (S/x + x) / 2
@0364:110442                    ad sqtmp
@0365:040440                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0366:100437                    ca SQARG
@0367:150440                    dv SQEST
@0370:155016                    slh 14
@0371:040442                    ts sqtmp
@0372:100440                    ca SQEST
@0373:161001                    srh 1
@0374:110442                    ad sqtmp
@0375:040440                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0376:100437                    ca SQARG
@0377:150440                    dv SQEST
@0400:155016                    slh 14
@0401:040442                    ts sqtmp
@0402:100440                    ca SQEST
@0403:161001                    srh 1
@0404:110442                    ad sqtmp
@0405:040440                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0406:100437                    ca SQARG
@0407:150440                    dv SQEST
@0410:155016                    slh 14
@0411:040442                    ts sqtmp
@0412:100440                    ca SQEST
@0413:161001                    srh 1
@0414:110442                    ad sqtmp
@0415:040440                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0416:100437                    ca SQARG
@0417:150440                    dv SQEST
@0420:155016                    slh 14
@0421:040442                    ts sqtmp
@0422:100440                    ca SQEST
@0423:161001                    srh 1
@0424:110442                    ad sqtmp
@0425:040440                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0426:100437                    ca SQARG
@0427:150440                    dv SQEST
@0430:155016                    slh 14
@0431:040442                    ts sqtmp
@0432:100440                    ca SQEST
@0433:161001                    srh 1
@0434:110442                    ad sqtmp
@0435:110255                    ad const_15              ; ensure the result is greater or equal to the actual sqrt

@0436:074000             SQRET: sp 0                     ; @@WrittenBy a0351

