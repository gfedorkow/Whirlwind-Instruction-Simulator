                                ; DATA
                                ; =============================================================
@0422:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0336 ReadBy a0342 a0352 a0362 a0372 a0402 a0412
@0423:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0341 a0351 a0361 a0371 a0401 a0411 ReadBy a0343 a0346 a0353 a0356 a0363 a0366 a0373 a0376 a0403 a0406 a0413 a0416
@0424:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0340
@0425:000000             sqtmp: .word 0                  ; @@WrittenBy a0345 a0355 a0365 a0375 a0405 a0415 ReadBy a0350 a0360 a0370 a0400 a0410 a0420

