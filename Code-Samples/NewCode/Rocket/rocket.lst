                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ; [contrary to Claude's assertion, this sqrt approximation is off by
                                ; much more than one LSB; There's a big correction factor at the end to
                                ; prevent overflows elsewhere]
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0340:050425                    ta SQRET                 ; @@JumpedToBy a0116

@0341:040426                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0342:161001                    srh 1                    ; AC = S/2
@0343:110430                    ad SQHALF                ; AC = S/2 + 0.5
@0344:040427                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0345:100426                    ca SQARG
@0346:150427                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0347:155016                    slh 14                   ; AC = quotient from BR
@0350:040431                    ts sqtmp
@0351:100427                    ca SQEST                 ; AC = S/x + x
@0352:161001                    srh 1                    ; AC = (S/x + x) / 2
@0353:110431                    ad sqtmp
@0354:040427                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0355:100426                    ca SQARG
@0356:150427                    dv SQEST
@0357:155016                    slh 14
@0360:040431                    ts sqtmp
@0361:100427                    ca SQEST
@0362:161001                    srh 1
@0363:110431                    ad sqtmp
@0364:040427                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0365:100426                    ca SQARG
@0366:150427                    dv SQEST
@0367:155016                    slh 14
@0370:040431                    ts sqtmp
@0371:100427                    ca SQEST
@0372:161001                    srh 1
@0373:110431                    ad sqtmp
@0374:040427                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0375:100426                    ca SQARG
@0376:150427                    dv SQEST
@0377:155016                    slh 14
@0400:040431                    ts sqtmp
@0401:100427                    ca SQEST
@0402:161001                    srh 1
@0403:110431                    ad sqtmp
@0404:040427                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0405:100426                    ca SQARG
@0406:150427                    dv SQEST
@0407:155016                    slh 14
@0410:040431                    ts sqtmp
@0411:100427                    ca SQEST
@0412:161001                    srh 1
@0413:110431                    ad sqtmp
@0414:040427                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0415:100426                    ca SQARG
@0416:150427                    dv SQEST
@0417:155016                    slh 14
@0420:040431                    ts sqtmp
@0421:100427                    ca SQEST
@0422:161001                    srh 1
@0423:110431                    ad sqtmp
@0424:110244                    ad const_15              ; ensure the result is greater or equal to the actual sqrt

@0425:074000             SQRET: sp 0                     ; @@WrittenBy a0340

