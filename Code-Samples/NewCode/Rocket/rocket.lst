                                ; DATA
                                ; =============================================================
@0437:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0352 ReadBy a0356 a0366 a0376 a0406 a0416 a0426
@0440:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0355 a0365 a0375 a0405 a0415 a0425 ReadBy a0357 a0362 a0367 a0372 a0377 a0402 a0407 a0412 a0417 a0422 a0427 a0432
@0441:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0354
@0442:000000             sqtmp: .word 0                  ; @@WrittenBy a0361 a0371 a0401 a0411 a0421 a0431 ReadBy a0364 a0374 a0404 a0414 a0424 a0434

