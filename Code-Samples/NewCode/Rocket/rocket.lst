                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0335:050421                    ta SQRET

@0336:040422                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0337:161001                    srh 1                    ; AC = S/2
@0340:110424                    ad SQHALF                ; AC = S/2 + 0.5
@0341:040423                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0342:100422                    ca SQARG
@0343:150423                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0344:155016                    slh 14                   ; AC = quotient from BR
@0345:040425                    ts sqtmp
@0346:100423                    ca SQEST                 ; AC = S/x + x
@0347:161001                    srh 1                    ; AC = (S/x + x) / 2
@0350:110425                    ad sqtmp
@0351:040423                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0352:100422                    ca SQARG
@0353:150423                    dv SQEST
@0354:155016                    slh 14
@0355:040425                    ts sqtmp
@0356:100423                    ca SQEST
@0357:161001                    srh 1
@0360:110425                    ad sqtmp
@0361:040423                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0362:100422                    ca SQARG
@0363:150423                    dv SQEST
@0364:155016                    slh 14
@0365:040425                    ts sqtmp
@0366:100423                    ca SQEST
@0367:161001                    srh 1
@0370:110425                    ad sqtmp
@0371:040423                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0372:100422                    ca SQARG
@0373:150423                    dv SQEST
@0374:155016                    slh 14
@0375:040425                    ts sqtmp
@0376:100423                    ca SQEST
@0377:161001                    srh 1
@0400:110425                    ad sqtmp
@0401:040423                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0402:100422                    ca SQARG
@0403:150423                    dv SQEST
@0404:155016                    slh 14
@0405:040425                    ts sqtmp
@0406:100423                    ca SQEST
@0407:161001                    srh 1
@0410:110425                    ad sqtmp
@0411:040423                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0412:100422                    ca SQARG
@0413:150423                    dv SQEST
@0414:155016                    slh 14
@0415:040425                    ts sqtmp
@0416:100423                    ca SQEST
@0417:161001                    srh 1
@0420:110425                    ad sqtmp

@0421:074000             SQRET: sp 0                     ; @@WrittenBy a0335

