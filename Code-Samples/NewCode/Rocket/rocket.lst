                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0336:050422                    ta SQRET

@0337:040423                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0340:161001                    srh 1                    ; AC = S/2
@0341:110425                    ad SQHALF                ; AC = S/2 + 0.5
@0342:040424                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0343:100423                    ca SQARG
@0344:150424                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0345:155016                    slh 14                   ; AC = quotient from BR
@0346:040426                    ts sqtmp
@0347:100424                    ca SQEST                 ; AC = S/x + x
@0350:161001                    srh 1                    ; AC = (S/x + x) / 2
@0351:110426                    ad sqtmp
@0352:040424                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0353:100423                    ca SQARG
@0354:150424                    dv SQEST
@0355:155016                    slh 14
@0356:040426                    ts sqtmp
@0357:100424                    ca SQEST
@0360:161001                    srh 1
@0361:110426                    ad sqtmp
@0362:040424                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0363:100423                    ca SQARG
@0364:150424                    dv SQEST
@0365:155016                    slh 14
@0366:040426                    ts sqtmp
@0367:100424                    ca SQEST
@0370:161001                    srh 1
@0371:110426                    ad sqtmp
@0372:040424                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0373:100423                    ca SQARG
@0374:150424                    dv SQEST
@0375:155016                    slh 14
@0376:040426                    ts sqtmp
@0377:100424                    ca SQEST
@0400:161001                    srh 1
@0401:110426                    ad sqtmp
@0402:040424                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0403:100423                    ca SQARG
@0404:150424                    dv SQEST
@0405:155016                    slh 14
@0406:040426                    ts sqtmp
@0407:100424                    ca SQEST
@0410:161001                    srh 1
@0411:110426                    ad sqtmp
@0412:040424                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0413:100423                    ca SQARG
@0414:150424                    dv SQEST
@0415:155016                    slh 14
@0416:040426                    ts sqtmp
@0417:100424                    ca SQEST
@0420:161001                    srh 1
@0421:110426                    ad sqtmp

@0422:074000             SQRET: sp 0                     ; @@WrittenBy a0336

                                ; =============================================================
                                ; DATA
                                ; =============================================================
@0423:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0337 ReadBy a0343 a0353 a0363 a0373 a0403 a0413
@0424:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0342 a0352 a0362 a0372 a0402 a0412 ReadBy a0344 a0347 a0354 a0357 a0364 a0367 a0374 a0377 a0404 a0407 a0414 a0417
@0425:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0341
@0426:000000             sqtmp: .word 0                  ; @@WrittenBy a0346 a0356 a0366 a0376 a0406 a0416 ReadBy a0351 a0361 a0371 a0401 a0411 a0421

