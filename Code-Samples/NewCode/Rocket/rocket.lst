                                ; DATA
                                ; =============================================================
@0430:000000             SQARG: .word 0o0                ; saved input S @@WrittenBy a0343 ReadBy a0347 a0357 a0367 a0377 a0407 a0417
@0431:000000             SQEST: .word 0o0                ; current Newton estimate @@WrittenBy a0346 a0356 a0366 a0376 a0406 a0416 ReadBy a0350 a0353 a0360 a0363 a0370 a0373 a0400 a0403 a0410 a0413 a0420 a0423
@0432:040000            SQHALF: .word 0o040000           ; 0.5 in fixed-point @@ReadBy a0345
@0433:000000             sqtmp: .word 0                  ; @@WrittenBy a0352 a0362 a0372 a0402 a0412 a0422 ReadBy a0355 a0365 a0375 a0405 a0415 a0425

