                                ; =============================================================
                                ; SUBROUTINE: SQRT
                                ; Compute fixed-point square root via Newton-Raphson iteration.
                                ; written by Claude.ai & guy, Mar 30, 2026
                                ; [contrary to Claude's assertion, this sqrt approximation is off by
                                ; much more than one LSB; There's a big correction factor at the end to
                                ; prevent overflows elsewhere]
                                ;
                                ; Input:  AC = S, fixed-point, 0 < S < 1
                                ;         (1.0 = 0o077777, 0.25 = 0o020000, etc.)
                                ; Output: AC = sqrt(S), fixed-point, same format
                                ;
                                ; Method: x_{n+1} = (x_n + S/x_n) / 2
                                ;         dv leaves quotient in BR; slh 15 moves it to AC.
                                ;         Initial guess x0 = S/2 + 0.5
                                ;         6 iterations give full 15-bit accuracy.
                                ;
                                ; Uses: SQARG, SQEST
                                ; Does not call any subroutine.
                                ;
                                ; Subroutine linkage:
                                ;   Caller:   sp   SQRT       ; CALL - returns
                                ;             ...              ; AC = sqrt(S) on return
                                ; =============================================================
                          SQRT:
@0345:050432                    ta SQRET                 ; @@JumpedToBy a0116

@0346:040433                    ts SQARG                 ; save S; AC still = S

                                ; --- Initial guess: x0 = S/2 + 0.5 ---
@0347:161001                    srh 1                    ; AC = S/2
@0350:110435                    ad SQHALF                ; AC = S/2 + 0.5
@0351:040434                    ts SQEST                 ; x0

                                ; --- Iteration 1 ---
@0352:100433                    ca SQARG
@0353:150434                    dv SQEST                 ; BR = S / x  (AC = remainder, ignore)
@0354:155016                    slh 14                   ; AC = quotient from BR
@0355:040436                    ts sqtmp
@0356:100434                    ca SQEST                 ; AC = S/x + x
@0357:161001                    srh 1                    ; AC = (S/x + x) / 2
@0360:110436                    ad sqtmp
@0361:040434                    ts SQEST                 ; x1

                                ; --- Iteration 2 ---
@0362:100433                    ca SQARG
@0363:150434                    dv SQEST
@0364:155016                    slh 14
@0365:040436                    ts sqtmp
@0366:100434                    ca SQEST
@0367:161001                    srh 1
@0370:110436                    ad sqtmp
@0371:040434                    ts SQEST                 ; x2

                                ; --- Iteration 3 ---
@0372:100433                    ca SQARG
@0373:150434                    dv SQEST
@0374:155016                    slh 14
@0375:040436                    ts sqtmp
@0376:100434                    ca SQEST
@0377:161001                    srh 1
@0400:110436                    ad sqtmp
@0401:040434                    ts SQEST                 ; x3

                                ; --- Iteration 4 ---
@0402:100433                    ca SQARG
@0403:150434                    dv SQEST
@0404:155016                    slh 14
@0405:040436                    ts sqtmp
@0406:100434                    ca SQEST
@0407:161001                    srh 1
@0410:110436                    ad sqtmp
@0411:040434                    ts SQEST                 ; x4

                                ; --- Iteration 5 ---
@0412:100433                    ca SQARG
@0413:150434                    dv SQEST
@0414:155016                    slh 14
@0415:040436                    ts sqtmp
@0416:100434                    ca SQEST
@0417:161001                    srh 1
@0420:110436                    ad sqtmp
@0421:040434                    ts SQEST                 ; x5

                                ; --- Iteration 6: result stays in AC, no ts needed ---
@0422:100433                    ca SQARG
@0423:150434                    dv SQEST
@0424:155016                    slh 14
@0425:040436                    ts sqtmp
@0426:100434                    ca SQEST
@0427:161001                    srh 1
@0430:110436                    ad sqtmp
@0431:110251                    ad const_15              ; ensure the result is greater or equal to the actual sqrt

@0432:074000             SQRET: sp 0                     ; @@WrittenBy a0345

