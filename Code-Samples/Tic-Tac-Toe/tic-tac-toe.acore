@N2572:  // segment in the 16-segment display character.
@N2573:    {P0, P1}
@N2576:    {P1, P2},
@N2601:    {P2, P3},
@N2604:    {P3, P4},
@N2607:    {P4, P5},
@N2612:    {P5, P6},
@N2615:    {P6, P7},
@N2620:    {P7, P0},
@N2623:    {P0, P8},
@N2626:    {P1, P8},
@N2631:    {P2, P8},
@N2634:    {P3, P8},
