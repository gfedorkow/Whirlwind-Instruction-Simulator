                                      ; ------------------------
                                      ; Input Methods
                                      ; Autoclick plays out a game from a preset list of inputs, i.e., for a demo-mode
                                      ; This routine returns -1 for "no move this time", or a positive cell number if there is a a move to make
                                      ; To start autoclick, set the autoclick_move_counter to a positive number.  That number will be used to
                                      ; index into the click table to see what move to make next.
                                      ; Note that the number decrements, so it plays from the end of the table to the start.

@0113:177776  autoclick_move_counter: .word -1                 ; negative (including -0) means "no more automatic moves" @@WrittenBy a0144 ReadBy a0126 a0137 a0142
@0114:000004    autoclick_delay_init: .word 0o4                ; initial value for the number of refresh cycles to wait for the next move @@ReadBy a0135
@0115:000004   autoclick_delay_timer: .word 0o4                ; @@WrittenBy a0133 a0136 ReadBy a0130

@0116:000120          autoclick_tabp: .word autoclick_tab      ; @@ReadBy a0042 a0140
@0117:000124     autoclick_tab_lastp: .word autoclick_tab_last ; @@ReadBy a0041
                       autoclick_tab:
@0120:000000                          .word 0                  ; unused cell at offset -0
@0121:000010                          .word 8                  ; fourth move
@0122:000003                          .word 3                  ; third move
@0123:000001                          .word 1                  ; second move; play cell 1
                  autoclick_tab_last:
@0124:000004                          .word 4                  ; first move; play cell 4 (center)  (top left is cell zero)

