@2277:030000                  seg01d: .word HORIZ_RIGHT

@2300:007000                  seg02x: .word P2x                ;   {P2, P3},
@2301:011000                  seg02y: .word P2y
@2302:172267                  seg02d: .word DOWN_LEFT

@2303:006400                  seg03x: .word P3x                ;   {P3, P4},
