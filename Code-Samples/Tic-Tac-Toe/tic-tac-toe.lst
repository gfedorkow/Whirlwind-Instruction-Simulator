                                      ;
                                      ;=====================================================================================
                                      ; Start of Claude Code for OXO Algorithm
                                      ;=====================================================================================


                                      ; Code from Claude AI chatbot
                                      ; Mar 12, 2026
                                      ; Corrected Mar 14, 2026
                                      ; Revised Mar 15, 2026: MAKHOT extracted as subroutine,
                                      ;   SP annotations added, call graph added

                                      ; Corrections from original:
                                      ;  Octal numbers should be prefaced by "0o"
                                      ;  Strings terminated with -1 are faster
                                      ;  rc and rd need operands; default would be "0"
                                      ;  All non-instruction words in memory must be allocated with .word <value>
                                      ;  I haven't implemented a Flexowriter RD operation
                                      ;  sd not xr for XOR
                                      ;  md for AND (Multiply Digits)
                                      ;  sp is unconditional branch, cp is conditional (branches if AC negative)
                                      ;  dm 0 normalizes zero to -0 (negative); so cp after dm 0 branches on ZERO,
                                      ;    not nonzero -- many branches were inverted in original code
                                      ;  WINTBLADDR must equal actual address of WINTBL
                                      ;  CWLD address field must be reloaded from WINTBLADDR at start of each CWLOOP call
                                      ;  slh changed to srh in MAKHOT (squares go right from SQ0MASK, not left)
                                      ;  MAKHOT extracted as proper subroutine (was inlined in 4 places)

                                      ; =============================================================
                                      ; TIC-TAC-TOE FOR WHIRLWIND I
                                      ; MIT Lincoln Laboratory, circa 1958
                                      ;
                                      ; Board squares numbered 0-8:
                                      ;   0 | 1 | 2
                                      ;   ----------
                                      ;   3 | 4 | 5
                                      ;   ----------
                                      ;   6 | 7 | 8
                                      ;
                                      ; Board state: two words BRDX (computer=X) and BRDO (human=O).
                                      ; Each is a 9-bit pattern in bit positions 6..14 of a 16-bit word.
                                      ; Bit 6 (value 2^-6 = octal 01000) = square 0
                                      ; Bit 7 (value 2^-7 = octal 00400) = square 1
                                      ; ...
                                      ; Bit 14 (value 2^-14 = octal 00002) = square 8
                                      ;
                                      ; Since BRDX and BRDO are always disjoint, sd (XOR) == OR for them.
                                      ;
                                      ; Square masks:
                                      ;   sq0 = 01000, sq1 = 00400, sq2 = 00200
                                      ;   sq3 = 00100, sq4 = 00040, sq5 = 00020
                                      ;   sq6 = 00010, sq7 = 00004, sq8 = 00002
                                      ;
                                      ; Win-line masks (OR of three square masks):
                                      ;   Row 0: 01600  Row 1: 00160  Row 2: 00016
                                      ;   Col 0: 01110  Col 1: 00444  Col 2: 00222
                                      ;   Diag0: 01042  Diag1: 00250
                                      ;
                                      ; SUBROUTINE LINKAGE (standard Whirlwind pattern):
                                      ;   Caller:      sp   SUBNAME       ; CALL - returns
                                      ;   Entry:       ta   SUBRET        ; save return addr from AR
                                      ;   Exit:        sp   SUBRET
                                      ;   Placeholder: SUBRET: sp 0
                                      ;
                                      ; SP ANNOTATION CONVENTION:
                                      ;   sp  LABEL   ; CALL - returns    (subroutine call, will return)
                                      ;   sp  LABEL   ; JUMP - no return  (unconditional jump, does not return)
                                      ;
                                      ; ONES-COMPLEMENT NOTES:
                                      ;   Zero test: dm 0 normalizes +-0 to -0; then cp branches on zero.
                                      ;   cp branches if AC is NEGATIVE.
                                      ;   After dm 0: zero result -> -0 (negative) -> cp BRANCHES
                                      ;               nonzero result -> positive -> cp FALLS THROUGH
                                      ;   So the idiom is:
                                      ;     dm 0
                                      ;     cp  ISZERO     ; branches here if zero
                                      ;                    ; falls through if nonzero
                                      ;   All integers stored as n * 2^-15 (fractional representation).
                                      ;   UNIT = 1 * 2^-15 = smallest positive value = octal 00001.
                                      ;
                                      ; =============================================================
                                      ; CALL GRAPH
                                      ;
                                      ; START / GAMELOOP (main program, not a subroutine)
                                      ;   sp PRBANNER         ; CALL
                                      ;     sp PRSTR          ; CALL
                                      ;   sp PRMBOARD         ; CALL
                                      ;     sp MAKHOT         ; CALL (x9, once per square)
                                      ;     sp PRSEP          ; CALL (x2, after rows 0 and 1)
                                      ;   sp PRMPRMT          ; CALL
                                      ;     sp PRSTR          ; CALL
                                      ;   sp GETMOV           ; CALL
                                      ;     sp MAKHOT         ; CALL
                                      ;     sp CWLOOP         ; CALL (win check for human)
                                      ;     sp COMPMOV        ; CALL
                                      ;       sp TRYMOVES     ; CALL (x2, win and block)
                                      ;         sp MAKHOT     ; CALL (once per square tried)
                                      ;         sp CWLOOP     ; CALL (once per free square)
                                      ;       sp TRYFREE      ; CALL (up to 8 times, corners+edges)
                                      ;     sp CWLOOP         ; CALL (win check for computer)
                                      ;     sp PRMCOMPMOV     ; CALL
                                      ;       sp PRSTR        ; CALL
                                      ;       sp MAKHOT       ; CALL (once per square searched)
                                      ;   sp PRMHWIN/PRMCWIN/PRMDRAW/PRMBADMOV/PRMSQTKN  ; CALL
                                      ;     sp PRSTR          ; CALL
                                      ;
                                      ; NOTE: MAKHOT is never active simultaneously with itself,
                                      ;   so it is safe as a non-reentrant subroutine.
                                      ; NOTE: CWLOOP calls nothing, so no reentrancy issue even
                                      ;   though it is called from within TRYMOVES.
                                      ; NOTE: PRSTR is never called while another PRSTR is active.
                                      ; =============================================================

                                      ; =============================================================
                                      ; MAIN PROGRAM
                                      ; =============================================================
                                      ; START:
                                      ;         ca   ZERO
                                      ;         ts   BRDX
                                      ;         ts   BRDO
                                      ;         ts   TURN
                                      ;
                                      ;         sp   PRBANNER          ; CALL - returns
                                      ;
                                      ; GAMELOOP:
                                      ;         sp   PRMBOARD          ; CALL - returns
                                      ;         sp   PRMPRMT           ; CALL - returns
                                      ;         sp   GETMOV            ; CALL - returns
                                      ;         sp   GAMELOOP          ; JUMP - no return



                                      ; =============================================================
                                      ; SUBROUTINE: GETMOV
                                      ; Read next human move, validate, convert to one-hot in BMOVE,
                                      ; take computer turn, check for end of game.
                                      ; User cell number is in the ACC
                                      ; =============================================================
                              GETMOV:
@0751:051047                          ta GMRET                 ; @@JumpedToBy a0601 a1052 a1055
                                      ;        ts   input   ; save the input cell number


                                      ; Validate <= 8:
@0752:042005                          ts SQIDX                 ; save the input cell number
@0753:116032                          su NINE_VAL              ; negative if index < 9
@0754:070756                          cp GOODRANGE
@0755:075050                          sp BADMOV                ; JUMP - no return

                           GOODRANGE:
@0756:102005                          ca SQIDX                 ; @@JumpedToBy a0754
@0757:075075                          sp MAKHOT                ; CALL - returns
@0760:042004                          ts BMOVE

                                      ; Check square not taken by X:
