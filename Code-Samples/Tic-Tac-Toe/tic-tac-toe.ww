
; Tic Tac toe
; Guy Fedorkow
; Sep 26, 2024

; May 24, 2026 - there's a non-critical bug still in the display of the WW
; move in FF3 -- the first move is computed by table, and the result is the cell number
; multiplied by 3.  To display the move properly, I "should" divide the number by 3.

; Simple game of tic-tac-toe written in Whirlwind assembly code.
; The game displays on the WW CRT, and can be played with the light gun
; (As of Sep 26, it's a two-person game, i.e., i alternates X and O plays)

; Geometry
; the basic game board is laid out on a 16x16 grid as follows:

;  cell 0   | cell 1   |  cell 2
;  @(4,12)  | @(8,12)  |  @(12,12)
; --------------------------------
;  cell 3   | cell 4   |  cell 5
;  @(4,8)   | @(8,8)   |  @(12,8)
; --------------------------------
;  cell 6   | cell 7   |  cell 8
;  @(4,4)   | @(8,4)   |  @(12,4)

;----------- old layout ----------
;  cell 6   | cell 7   |  cell 8
;  @(4,12)  | @(8,12)  |  @(12,12)
; --------------------------------
;  cell 3   | cell 4   |  cell 5
;  @(4,8)   | @(8,8)   |  @(12,8)
; --------------------------------
;  cell 0   | cell 1   |  cell 2
;  @(4,4)   | @(8,4)   |  @(12,4)
;-------------------------------

          .org 0
zero:
const_0:  .word 0
one:
const_1:  .word 1

        .pp FF2_USER_MOVE, 02    ; display cell number of last User move
        .pp FF3_WW_MOVE,   03    ; display cell number of last WW move

;          ; state values for which_player var.  These index into state_msg_table
;        .pp NAUGHT_PLAY_STATE,  0
;        .pp CROSS_PLAY_STATE,   1
;        .pp HWIN_PLAY_STATE,    2
;        .pp CWIN_PLAY_STATE,    2
;        .pp DRAW_PLAY_STATE,    2
;
        


; constants for SI graphics instruction
            .pp scope_vector, 0o1677   ; draw a vector on all scopes
            .pp scope_point, 0o0677   ; draw a point on all scopes



            .org 0o40
;

main:       sp init_game_board      ; call the init subroutine
            sp refresh_loop         ; branch to main display refresh loop

; constants
c_15:       .word 15
c_32:       .word 32
c_scope_edge: .word 950 * 32        ; close to the edge of the scope screen
c_msg_x_pos:  .word 800 * 32

refresh_loop:
            sp PRMPRMT   ; CALL - print "your move"
refloop:
            sp draw_game_board
            ca g_game_over          ; negative value means "game over"
            cp refloop
            sp is_there_winner      ; check to see if this user move ended the game
            ca which_player         ; if which_player is not zero, then the game has ended 
            dm zero
            cp rl_continue_game
            sp set_game_over        ; negative means no more moves

rl_continue_game:
            ca light_gun_mailbox
            ad one                  ; convert -0 (cell zero) into +1 before the next CP test, then discard the result
            cp refloop
            .print "light gun hit at cell %d", light_gun_mailbox
            ; user_play_cell goes straight to the mailbox to find the current cell number.
            sp user_play_cell   ; do something with the light gun hit!  ; this call is for person-vs-computer play
            cs one                ; put -1 in the mailbox to indicate Empty
            ts light_gun_mailbox  ; mark the mailbox as empty

            sp refloop

set_game_over:  cs one              ; the game_over flag starts set to zero by init_game_board
            ts g_game_over          ; But when the game is over, we set it to -1
            sp refresh_loop



; ************* Refresh the game board display ********************
; draw the tic-tac-toe grid
; two horizontal lines first
draw_game_board:
            ta draw_game_board_ret
            
            sp refresh_game_state  ; subroutine to collect the current board from the oxo algorithm
            
            cs const_2
            ts loop_count
            ca const_6
            ts y_arg
x_grid_loop:
            ca const_2
            ts x_arg
            cs const_11
            ts n_segments  ; segment count should be negative, ie, we will incr the value until positive
            sp draw_x_line

            ca const_10
            ts y_arg          
            ao loop_count
            cp x_grid_loop

; two vertical lines next
            cs const_2
            ts loop_count
            ca const_6
            ts x_arg
y_grid_loop:
            ca const_2
            ts y_arg
            cs const_11
            ts n_segments  ; segment count should be negative, ie, we will incr the value until positive
            sp draw_y_line

            ca const_10
            ts x_arg          
            ao loop_count
            cp y_grid_loop

; Draw the game_state, ie, dots, naughts, or crosses
draw_game_state:
            cs const_8  ; nine passes; var should be 8; loop count is negative
            ts loop_count
            ca gb_table_start
            ts next_x_addr
            ad const_1        
            ts next_y_addr
            ad const_1
            ts next_gb_state_addr
            cs one
            ts light_gun_mailbox
gb_loop:
gb_x_inst:  ca next_x_addr
            ts x_addr_arg
gb_y_inst:  ca next_y_addr
            ts y_addr_arg
gb_gs_inst: ca next_gb_state_addr
            td ca_addr
ca_addr:    ca 0
            td gb_state_sp
gb_state_sp: sp 0   ; draw the X, O or dot; this call may have a side-effect of seeing a light-gun hit

            ; increment pointers and loop count for the next pass
            ca next_x_addr
            ad const_3
            ts next_x_addr
            ca next_y_addr
            ad const_3
            ts next_y_addr
            ca next_gb_state_addr
            ad const_3
            ts next_gb_state_addr
            ao loop_count
            cp gb_loop

draw_current_player:            ; draw an alpha string at the bottom of the screen to show the state of the game

            ca which_player     ; see definition for this number
            md const_7          ; clear the sign bit in case of "Game Over"
            ad state_msg_tablep
            td dcp_ca_addr

            cs c_scope_edge     ; set the location to draw a string
            ts ds_argy
            cs c_msg_x_pos
            ts ds_argx
dcp_ca_addr:
            ca 0        ; get the pointer to the string into ACC
            sp draw_str   ; "print" the string on the screen

            sp draw_reset_symbol  ; draw the symbol to call for a game reset

draw_game_board_ret:    ; return from the 'board display' subroutine
            sp 0



          
; ephemeral loop state variables
next_x_addr:  .word 0
next_y_addr:  .word 0
next_gb_state_addr: .word 0
light_gun_mailbox:  .word -1  ; used to pass light-gun hits back from the drawing routine.  Negative means "no hit"

loop_count:  ; used only in top-level routines for drawing the game board
          .word 0


; Arguments to pass into routines
x_arg:    .word 0
y_arg:    .word 0
x_addr_arg:    .word 0   ; pointer to x_addr
y_addr_arg:    .word 0
n_segments: .word 0
gb_state_arg: .word 0

;  Game Play State
; this var is zero or one to show which player is on-deck for the next move
; But it can also be set to negative to say "Game Over", or 2 to say Win, three to say Draw/Tie
; The var, less the sign bit, is used to index player_icon_table below
which_player:   .word 0     

player_state_x_addr:  .word 7   ; These two constants control where the X or O indicator lands on the screen
player_state_y_addr:  .word 1
player_state_x_ptr:   .word player_state_x_addr
player_state_y_ptr:   .word player_state_y_addr

; Static lookup table to find how to draw the current player state
; The table is a pointer to subroutine entry points
player_icon_table: .word dct0
dct0:       .word draw_cross
dct1:       .word draw_naught
;dct2:       .word draw_win
;dct3:       .word draw_tie

state_msg_tablep:  .word state_msg_table
state_msg_table:
            .word msg_naught_play
            .word msg_cross_play
            .word msg_o_win
            .word msg_x_win
            .word msg_draw


msg_cross_play:
;            .flexl "PLAYER X"
            .word 0o000054
            .word 0o000044
            .word 0o000006
            .word 0o000052
            .word 0o000002
            .word 0o000024
            .word 0o000010
            .word 0o000072
            .word -1

msg_naught_play:
;            .flexl "PLAYER O"
            .word 0o054
            .word 0o044
            .word 0o006
            .word 0o052
            .word 0o002
            .word 0o024
            .word 0o010
            .word 0o060
            .word -1

msg_x_win:
;            .flexl "X WIN"
            .word 0o072
            .word 0o010
            .word 0o046
            .word 0o014
            .word 0o030
            .word -1

msg_o_win:
;            .flexl "O WIN"
            .word 0o060
            .word 0o010
            .word 0o046
            .word 0o014
            .word 0o030
            .word -1

msg_draw:
;            .flexl "DRAW"
            .word 0o022
            .word 0o024
            .word 0o006
            .word 0o046
            .word -1



; Game State Variables
; The Game Table is a nine-entry array that has one entry for each cell of the game board.
; The position of each cell on the game board is static, but the "state" var shows
; whether the cell contains a dot, a naught or a cross
gb_table_start: .word gb0_x
; Game Board State
gb0_x:    .word 4
gb0_y:    .word 12
gb0_state: .word draw_dot
gb1_x:    .word 8
gb1_y:    .word 12
gb1_state: .word draw_dot
gb2_x:    .word 12
gb2_y:    .word 12
gb2_state: .word draw_dot
gb3_x:    .word 4
gb3_y:    .word 8
gb3_state: .word draw_dot
gb4_x:    .word 8
gb4_y:    .word 8
gb4_state: .word draw_dot
gb5_x:    .word 12
gb5_y:    .word 8
gb5_state: .word draw_dot
gb6_x:    .word 4
gb6_y:    .word 4
gb6_state: .word draw_dot
gb7_x:    .word 8
gb7_y:    .word 4
gb7_state: .word draw_dot
gb8_x:    .word 12
gb8_y:    .word 4
gb8_state: .word draw_dot



; subroutine to draw a horizontal line
draw_x_line:
          ta draw_x_line_ret  ; save the return address
          ca y_arg
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          si scope_vector    ; initialize vector gen
          ca x_arg
          su const_8    ; shift from 0-15 axis to -8 to +7
          ts x_arg
next_x_seg:
          ca x_arg      ; re-fetch the next x_arg
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          
          rc horiz_line_seg  ; Draw a segment with x=ACC
          ao x_arg
          ao n_segments  ; increment the segment counter
          cp next_x_seg
draw_x_line_ret:
          sp 0

; subroutine to draw a vertical line
draw_y_line:
          ta draw_y_line_ret  ; save the return address
next_y_seg:          
          ca y_arg
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          si scope_vector    ; initialize vector gen with the y-coord in ACC
          ca x_arg
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          
          rc vert_line_seg  ; Draw a segment with x=ACC
          ao y_arg
          ao n_segments  ; increment the segment counter
          cp next_y_seg
draw_y_line_ret:          
          sp 0




; subroutine to draw a light-gun dot in an unplayed game cell
; the args into this routine are addresses of x and y locations, not
; the locations themselves
draw_dot:
            ta draw_dot_ret   ; save return address
            ca which_player     ; test to see if there's another move allowed
            cp draw_dot_ret     ; if the var is negative, we're done playing
            
            ca y_addr_arg       ; assuming the game's not over, we continue to draw
            td dd_y_arg
dd_y_arg:   ca 0
            su const_8
            slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
            si scope_point    ; initialize point gen with the y-coord in ACC
            ca x_addr_arg
            td dd_x_arg
dd_x_arg:   ca 0
            su const_8    ; shift from 0-15 axis to -8 to +7
            slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
            rc 0          ; Draw a pont with x=ACC
            rd 0          ; read the light gun
            cp light_gun_cell_hit    ; call a subroutine to handle the light gun.  The gun number is in ACC
draw_dot_ret: 
            sp 0


; draw an "X" centered on the screen at the position of the x and y args
; args are passed as addresses  
draw_cross:
          ta draw_cross_ret
          
          ca y_addr_arg
          td dc_y_arg
dc_y_arg:  ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          si scope_vector    ; initialize vector gen with the y-coord in ACC
          ca x_addr_arg
          td dc_x_arg
dc_x_arg: ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          
          rc diag_up_right_seg  ; Draw a segment with x=ACC
          rc diag_dn_left_seg   ; Draw a segment with x=ACC
          rc diag_up_left_seg   ; Draw a segment with x=ACC
          rc diag_dn_right_seg  ; Draw a segment with x=ACC
draw_cross_ret:
          sp 0

; draw an "naught" (i.e. a diamond) centered on the screen at the position of the x and y args
; args are passed as addresses  
draw_naught:
            ta draw_naught_ret
            
            ca y_addr_arg
            td dn_y_arg
dn_y_arg:  ca 0
            su const_8    ; shift from 0-15 axis to -8 to +7
            slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
            si scope_vector    ; initialize vector gen with the y-coord in ACC
            ca x_addr_arg
            td dn_x1_arg
dn_x1_arg: ca 0
            su const_9    ; shift from 0-15 axis to -8 to +7; plus an offset
            slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
            
            rc diag_up_right_seg  ; Draw a segment with x=ACC
            rc diag_dn_right_seg  ; Draw a segment with x=ACC
            
            ad const_2_cell   ; shift the x-pos two cells right
            rc diag_up_left_seg  ; Draw a segment with x=ACC
            rc diag_dn_left_seg  ; Draw a segment with x=ACC
          
draw_naught_ret:
            sp 0

; placeholder to draw a Win symbol centered on the screen at the position of the x and y args
; args are passed as addresses  
draw_win:
          ta draw_win_ret
          
          ca y_addr_arg
          td dw_y_arg
dw_y_arg:  ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          si scope_vector    ; initialize vector gen with the y-coord in ACC
          ca x_addr_arg
          td dw_x_arg
dw_x_arg: ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          
          rc diag_up_right_seg  ; Draw a segment with x=ACC
;          rc diag_dn_left_seg   ; Draw a segment with x=ACC
          rc diag_up_left_seg   ; Draw a segment with x=ACC
;          rc diag_dn_right_seg  ; Draw a segment with x=ACC
draw_win_ret:
          sp 0

; placeholder to draw a Tie symbol centered on the screen at the position of the x and y args
; args are passed as addresses  
draw_tie:
          ta draw_tie_ret
          
          ca y_addr_arg
          td dt_y_arg
dt_y_arg:  ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; multiply by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          si scope_vector    ; initialize vector gen with the y-coord in ACC
          ca x_addr_arg
          td dt_x_arg
dt_x_arg: ca 0
          su const_8    ; shift from 0-15 axis to -8 to +7
          slr 12        ; gb_state_arg by 128 to get +/- 1024 screen coords, multiply by 64 to get to bit 0
          
;          rc diag_up_right_seg  ; Draw a segment with x=ACC
          rc diag_dn_left_seg   ; Draw a segment with x=ACC
;          rc diag_up_left_seg   ; Draw a segment with x=ACC
          rc diag_dn_right_seg  ; Draw a segment with x=ACC
draw_tie_ret:
          sp 0


draw_reset_symbol:
            ta draw_reset_symbol_ret
            cs const_7; put the point at game-board coord (1, 1)
            slr 12
            ; ACC contains the coord; use the same number for x and y
            si scope_point    ; initialize point gen with the y-coord in ACC
            rc 0          ; Draw a pont with x=ACC
            rd 0          ; read the light gun
            cp init_game_board    ; call a subroutine to handle the light gun. 

draw_reset_symbol_ret:
            sp 0



; ***************************  User Interaction ***********************

; Handle a user light_gun hit on one of the game cells 
; Remember that this is called only from the routine that draws a
; dot in the middle of a cell on the game grid.
; This routine converts the y_address from screen polarity (more positive is up)
; to Game Board polarity (numbered from top=0 to bottom=2) by subtracting the 
; light gun coord from three.
; The light gun number is passed to this routine in ACC 
light_gun_cell_hit:
            ta light_gun_cell_hit_ret

            ts lcl_gun_num
            ca x_addr_arg
            td lgh_x1_arg
lgh_x1_arg: ca 0        ; load the x value of the cell's address in the grid
            srr 2       ; divide the cell x address by four to get 1, 2, or 3
            su const_1    ; change from one-base to zero-base
            ts lcl_cell_x

            ca y_addr_arg   ; repeat the process for the y coordinate
            td lgh_y1_arg
lgh_y1_arg: ca 0        ; load the y value of the cell's address in the grid
            srr 2       ; divide the cell y address by four to get 1, 2, or 3
            sd const_0n ; invert to get negative number
            ad const_3    ; change from one-base to zero-base and invert order
            ts lcl_cell_y
            slh 1       ; multiply y by three, i.e., double then add address
            ad lcl_cell_y
            ad lcl_cell_x  ; add x to get the cell number in the range 0-8

            .print "light gun %o hit x=%o, y=%o, cell=%ao", lcl_gun_num, lcl_cell_x, lcl_cell_y

            ; the cell number of the hit is passed below in ACC
            ts light_gun_mailbox
            ts FF2_USER_MOVE   ; display the move

            sp is_there_winner       ; test to see if it's Game Over

light_gun_cell_hit_ret: sp 0

; temp vars for figuring the cell number in light_gun_cell_hit
lcl_cell_x: .word 0
lcl_cell_y: .word 0
lcl_gun_num: .word 0


; "Play" a cell
; This routine does a simple two-person-style play; each light gun hit simply alternates
; between X and O
; The Cell Number to play is passed in the ACC
; Note that this routine can only be called on a previously-unplayed cell, 'cause those
; are the only ones with dots in them, and that's all the light gun can see
alternate_play_cell:
            ta alternate_play_cell_ret

            ts lcl_aplay_cell_num    ; figure the pointer to the first cell draw function in game table
            slh 1                   ;  thats table_start + 3*cwll_num + 2
            ad lcl_aplay_cell_num    ; multiply cell number by three for a table offset
            ad gb_table_start
            ad const_2
            td apc_table_ts

            ca player_icon_table    ; figure out what the new cell should be
            ad which_player
            td apc_ca0
apc_ca0:    ca 0                    ; ACC should now contain the address of the X or O display routine
apc_table_ts: ts 0                  ; store the display routine to the game state table

            ; now switch to the other player for the next move
            ca which_player
            sd const_1              ; xor a 1 into the LSB; i.e. 0->1 or 1->0
            ts which_player

alternate_play_cell_ret:
            sp 0
lcl_aplay_cell_num: .word 0



; This routine plays person against computer; each light gun hit plays an Cross,
; then the machine plays Naught
; Note that this routine can only be called on a previously-unplayed cell, 'cause those
; are the only ones with dots in them, and that's all the light gun can see.
; The number of the cell being played (was) in ACC
; Modified Aug 2, 2025 to pick up the cell number of the last light gun hit directly
; from the mailbox
user_play_cell:
            ta user_play_cell_ret

            ca light_gun_mailbox     ; fetch the cell number
            ts lcl_uplay_cell_num    ; figure the pointer to the first cell draw function in game table
;                  slh 1                   ;  thats table_start + 3*cell_num + 2
;                  ad lcl_uplay_cell_num    ; multiply cell number by three for a table offset
;                  ad gb_table_start
;                  ad const_2
;                  td upc_table_ts
;      
;                  ca player_icon_table    ; figure out what the new cell should be
;                  ad which_player
;                  td upc_ca0
;      upc_ca0:    ca 0                    ; ACC should now contain the address of the X or O display routine
;      upc_table_ts: ts 0                  ; store the display routine to the game state table
;      
;                  sp is_there_winner      ; check to see if this user move ended the game
;                  cp upc_cleanup          ; negative means no more moves

            ; now switch to the other player for the next move
            ; auto_play_move calls claude oxo to figure the best move, then makes the move
            ; by updating the icon on the game board.
            ; ACC contains the user-cell
            sp auto_play_move

user_play_cell_ret:
            sp 0
lcl_uplay_cell_num: .word 0





; set up to call findBestMove
; Upon entry, ACC should be the cell the user wants to play
auto_play_move:
            ta apm_ret
            sp GETMOV     ; CALL to post the user's move and respond
apm_ret:
            sp 0

apm_panic:
            .print "APM_Panic Halt: not dot, cross or naught in auto_play_move"
            sp 0


;;;;;;;;;;;;;;;;;

is_there_winner:
            ta is_there_winner_ret

is_there_winner_ret:
            sp 0




; static addresses
dot_fn_addr:    .word draw_dot
cross_fn_addr:  .word draw_cross
naught_fn_addr: .word draw_naught



;;;;;;;;;;;;;;;;
; Set all the game board cells to "unplayed"
; Initialize the game state
init_game_board:
            ta init_game_board_ret

            ca zero                 ; Reset the Move Counter to Zero
            ts BRDX                 ; reset the Claude game state vars
            ts BRDO
            ts TURN
            ts which_player

            ca gb_table_start       ; calculate the offset into the game state table for this cell
            ad const_2              ; offset to third table entry
            td igb_table_ts         ; store the pointer to the first entry

            cs const_8  ; nine passes; var should be 8; loop count is negative
            ts loop_count
igb_loop:   ca lcl_init_val         ; fetch the address to use for the initial function pointer for each cell   
igb_table_ts: ts 0                  ; set a table entry to the default pointer
            ca igb_table_ts         ; advance the pointer to the next entry
            ad const_3
            ts igb_table_ts
            ao loop_count
            cp igb_loop             ; around the loop until we've hit all nine entries

            ca zero
            ts which_player
            ts g_game_over          ; clear the "game over" flag
            
            cs one
            ts light_gun_mailbox
            ts FF2_USER_MOVE            



            ;;;;;;
init_game_board_ret:
            sp 0
lcl_init_val: .word draw_dot
g_game_over:  .word 0

; ****************************************


; Constants
const_0n: .word 0o177777
const_2:  .word 2
const_3:  .word 3
const_4:  .word 4
const_6:  .word 6
const_7:  .word 7
const_8:  .word 8
const_9:  .word 9
const_10: .word 10
const_11: .word 11    ; loop counter for 12 iterations
const_12: .word 12
const_2_cell: .word 8192   ; decimal value of screen coord corresponding to two cells in width

const_x_win: .word 0o100002      ; two plus sign bit
const_o_win: .word 0o100003      ; two plus sign bit
const_draw:  .word 0o100004     ; three plus sign bit


; these two constants give the delta values to draw a "maximum short vector"
horiz_line_seg:    .word 0o174 * 0o400   ; +32 in the top half of the word
vert_line_seg:     .word 0o174            ; +32 in the bottom half of the word
diag_up_right_seg: .word 0o174 * 0o400 + 0o174
diag_dn_left_seg:  .word 0o200 * 0o400 + 0o200
diag_dn_right_seg: .word 0o174 * 0o400 + 0o200
diag_up_left_seg:  .word 0o200 * 0o400 + 0o174


; ---------------------------------------

panic_stop:
        ca 0
        .print "panic stop"
        si 0


        ; ;these are the values to be placed in a cell on the board to show
        ; who's playing which position
        .pp XX, 1
        .pp Oh, 2
        .pp None, -1

; Constants
c_2:    .word  2
c_2n:   .word -2    ; for a loop of three
c_3:    .word  3
c_4:    .word  4
c_8n:   .word -8    ; for a loop of nine passes
c_10:   .word 10
c_1000: .word 1000  ; BigNum
c_XX:   .word XX
c_oh:   .word Oh




;=====================================================================================
; Claude-OXO to Guy-Code Glue and Conversion
;=====================================================================================

refresh_game_state:
            ta rgs_ret
            ca gb_table_start
            ad const_1        
            ad const_1
            ts next_gb_state_addr
        
            ca   ZERO
            ts   SQIDX

            ; we shall proceed through this loop starting from cell 0
glueLOOP:

            ca next_gb_state_addr  ; this location contains a function pointer to say how to display the cell
            td gl_ca_addr

            ca   SQIDX
            sp   MAKHOT            ; CALL - returns
            ts   TBIT
    
            ca   TBIT
            md   BRDX
            dm   0
            cp   glTRYO              ; zero -> not X
            sp   glPBPX              ; JUMP 
    glTRYO:
            ca   TBIT
            md   BRDO
            dm   0
            cp   glTRYEMPTY          ; zero -> not O
            sp   glPBPO              ; JUMP 
    glTRYEMPTY:
            ca   dot_fn_addr
            sp   glue_cont           ; JUMP
    
    glPBPX:
            ca   cross_fn_addr
            sp   glue_cont           ; JUMP
    
    glPBPO:
            ca   naught_fn_addr

            ; at this point, ACC contains the address of the function to fill in the cell, i.e., dot, x or o
glue_cont:
gl_ca_addr: ts 0   ; 

            ; increment pointers and loop count for the next pass
            ca next_gb_state_addr
            ad const_3
            ts next_gb_state_addr

        ; test for loop end
        ao   SQIDX
        su   NINE_VAL
        dm   0
        cp   rgs_ret             ; zero -> done
        sp   glueLOOP
        
rgs_ret: sp 0


; 
;=====================================================================================
; Start of Claude Code for OXO Algorithm
;=====================================================================================


; Code from Claude AI chatbot
; Mar 12, 2026
; Corrected Mar 14, 2026
; Revised Mar 15, 2026: MAKHOT extracted as subroutine,
;   SP annotations added, call graph added

; Corrections from original:
;  Octal numbers should be prefaced by "0o"
;  Strings terminated with -1 are faster
;  rc and rd need operands; default would be "0"
;  All non-instruction words in memory must be allocated with .word <value>
;  I haven't implemented a Flexowriter RD operation
;  sd not xr for XOR
;  md for AND (Multiply Digits)
;  sp is unconditional branch, cp is conditional (branches if AC negative)
;  dm 0 normalizes zero to -0 (negative); so cp after dm 0 branches on ZERO,
;    not nonzero -- many branches were inverted in original code
;  WINTBLADDR must equal actual address of WINTBL
;  CWLD address field must be reloaded from WINTBLADDR at start of each CWLOOP call
;  slh changed to srh in MAKHOT (squares go right from SQ0MASK, not left)
;  MAKHOT extracted as proper subroutine (was inlined in 4 places)

; =============================================================
; TIC-TAC-TOE FOR WHIRLWIND I
; MIT Lincoln Laboratory, circa 1958
;
; Board squares numbered 0-8:
;   0 | 1 | 2
;   ----------
;   3 | 4 | 5
;   ----------
;   6 | 7 | 8
;
; Board state: two words BRDX (computer=X) and BRDO (human=O).
; Each is a 9-bit pattern in bit positions 6..14 of a 16-bit word.
; Bit 6 (value 2^-6 = octal 01000) = square 0
; Bit 7 (value 2^-7 = octal 00400) = square 1
; ...
; Bit 14 (value 2^-14 = octal 00002) = square 8
;
; Since BRDX and BRDO are always disjoint, sd (XOR) == OR for them.
;
; Square masks:
;   sq0 = 01000, sq1 = 00400, sq2 = 00200
;   sq3 = 00100, sq4 = 00040, sq5 = 00020
;   sq6 = 00010, sq7 = 00004, sq8 = 00002
;
; Win-line masks (OR of three square masks):
;   Row 0: 01600  Row 1: 00160  Row 2: 00016
;   Col 0: 01110  Col 1: 00444  Col 2: 00222
;   Diag0: 01042  Diag1: 00250
;
; SUBROUTINE LINKAGE (standard Whirlwind pattern):
;   Caller:      sp   SUBNAME       ; CALL - returns
;   Entry:       ta   SUBRET        ; save return addr from AR
;   Exit:        sp   SUBRET
;   Placeholder: SUBRET: sp 0
;
; SP ANNOTATION CONVENTION:
;   sp  LABEL   ; CALL - returns    (subroutine call, will return)
;   sp  LABEL   ; JUMP - no return  (unconditional jump, does not return)
;
; ONES-COMPLEMENT NOTES:
;   Zero test: dm 0 normalizes +-0 to -0; then cp branches on zero.
;   cp branches if AC is NEGATIVE.
;   After dm 0: zero result -> -0 (negative) -> cp BRANCHES
;               nonzero result -> positive -> cp FALLS THROUGH
;   So the idiom is:
;     dm 0
;     cp  ISZERO     ; branches here if zero
;                    ; falls through if nonzero
;   All integers stored as n * 2^-15 (fractional representation).
;   UNIT = 1 * 2^-15 = smallest positive value = octal 00001.
;
; =============================================================
; CALL GRAPH
;
; START / GAMELOOP (main program, not a subroutine)
;   sp PRBANNER         ; CALL
;     sp PRSTR          ; CALL
;   sp PRMBOARD         ; CALL
;     sp MAKHOT         ; CALL (x9, once per square)
;     sp PRSEP          ; CALL (x2, after rows 0 and 1)
;   sp PRMPRMT          ; CALL
;     sp PRSTR          ; CALL
;   sp GETMOV           ; CALL
;     sp MAKHOT         ; CALL
;     sp CWLOOP         ; CALL (win check for human)
;     sp COMPMOV        ; CALL
;       sp TRYMOVES     ; CALL (x2, win and block)
;         sp MAKHOT     ; CALL (once per square tried)
;         sp CWLOOP     ; CALL (once per free square)
;       sp TRYFREE      ; CALL (up to 8 times, corners+edges)
;     sp CWLOOP         ; CALL (win check for computer)
;     sp PRMCOMPMOV     ; CALL
;       sp PRSTR        ; CALL
;       sp MAKHOT       ; CALL (once per square searched)
;   sp PRMHWIN/PRMCWIN/PRMDRAW/PRMBADMOV/PRMSQTKN  ; CALL
;     sp PRSTR          ; CALL
;
; NOTE: MAKHOT is never active simultaneously with itself,
;   so it is safe as a non-reentrant subroutine.
; NOTE: CWLOOP calls nothing, so no reentrancy issue even
;   though it is called from within TRYMOVES.
; NOTE: PRSTR is never called while another PRSTR is active.
; =============================================================

; =============================================================
; MAIN PROGRAM
; =============================================================
; START:
;         ca   ZERO
;         ts   BRDX
;         ts   BRDO
;         ts   TURN
; 
;         sp   PRBANNER          ; CALL - returns
; 
; GAMELOOP:
;         sp   PRMBOARD          ; CALL - returns
;         sp   PRMPRMT           ; CALL - returns
;         sp   GETMOV            ; CALL - returns
;         sp   GAMELOOP          ; JUMP - no return



; =============================================================
; SUBROUTINE: GETMOV
; Read next human move, validate, convert to one-hot in BMOVE,
; take computer turn, check for end of game.
; User cell number is in the ACC
; =============================================================
GETMOV:
        ta   GMRET
;        ts   input   ; save the input cell number


        ; Validate <= 8:
        ts   SQIDX             ; save the input cell number
        su   NINE_VAL          ; negative if index < 9
        cp   GOODRANGE
        sp   BADMOV            ; JUMP - no return

GOODRANGE:
        ca   SQIDX
        sp   MAKHOT            ; CALL - returns
        ts   BMOVE

        ; Check square not taken by X:
        ca   BMOVE
        md   BRDX
        dm   0
        cp   CHKOFREE          ; zero -> not taken by X
        sp   SQTKN             ; JUMP - no return
CHKOFREE:
        ; Check square not taken by O:
        ca   BMOVE
        md   BRDO
        dm   0
        cp   PLACEO            ; zero -> not taken by O
        sp   SQTKN             ; JUMP - no return
PLACEO:
        ; Place human's O:
        ca   BRDO
        sd   BMOVE
        ts   BRDO
        
        ; print the users move on the Flexo
        ca   SQIDX
        ad   flexo_num_tbl_ptr
        td   char_conv2
char_conv2: ca 0
        
        clc  0o12
        si   0o225
        rc 0
        
        ao   TURN

        ; Check if human won:
        ca   ZERO
        ts   WINFLG
        ca   BRDO
        ts   CWBD
        ca   EIGHT_VAL
        ts   CWLCNT
        sp   CWLOOP            ; CALL - returns

        ca   WINFLG
        dm   0
        cp   H_NON_WIN        ; zero -> human did not win
        sp   HUMAN_WIN         ; JUMP - no return
H_NON_WIN:

        ; Check draw:
        ca   TURN
        su   NINE_VAL
        dm   0
        cp   DRAW              ; JUMP - no return (zero -> draw)

        ; Computer's turn:
        sp   COMPMOV           ; CALL - returns

        ; Place computer's X:
        ca   BRDX
        sd   BMOVE
        ts   BRDX

        ao   TURN

        ; Check if computer won:
        ca   ZERO
        ts   WINFLG
        ca   BRDX
        ts   CWBD
        ca   EIGHT_VAL
        ts   CWLCNT
        sp   CWLOOP            ; CALL - returns

        ca   WINFLG
        dm   0
        cp   AFTER_CWIN        ; zero -> computer did not win
        sp   COMP_WIN          ; JUMP - no return
AFTER_CWIN:

        sp   PRMCOMPMOV        ; CALL - returns
        sp   PRMBOARD          ; CALL - returns

GMRET:  sp   0


BADMOV:
        sp   PRMBADMOV         ; CALL - returns
        .word 0o0              ; HALT
        sp   GETMOV            ; JUMP - no return (dead after HALT)

SQTKN:
        sp   PRMSQTKN          ; CALL - returns
        .word 0o0              ; HALT
        sp   GETMOV            ; JUMP - no return (dead after HALT)

HUMAN_WIN:
        sp   PRMBOARD          ; CALL - returns
        sp   PRMHWIN           ; CALL - returns
        ca const_o_win
        ts which_player
        sp   refresh_loop      ; JUMP - no return

COMP_WIN:
        sp   PRMBOARD          ; CALL - returns
        sp   PRMCWIN           ; CALL - returns
        ca const_o_win
        ts which_player
        sp   refresh_loop      ; JUMP - no return

DRAW:
        sp   PRMBOARD          ; CALL - returns
        sp   PRMDRAW           ; CALL - returns
        ca const_draw
        ts which_player
        sp   refresh_loop      ; JUMP - no return

;input:  .word 0

; =============================================================
; SUBROUTINE: MAKHOT
; Convert square index to one-hot mask.
; Input:  AC = square index (0..8)
; Output: AC = one-hot mask (SQ0MASK shifted right by index)
; Uses:   CURMSK, CNTR
; =============================================================
MAKHOT:
        ta   MHRET
        ts   CNTR              ; CNTR = shift count = square index
        ca   SQ0MASK
        ts   CURMSK
MHLOOP:
        ca   CNTR
        dm   0
        cp   MHDONE            ; zero -> done
        sp   MHSHIFT           ; JUMP - no return
MHSHIFT:
        ca   CURMSK
        srh  1                 ; shift right 1, hold
        ts   CURMSK
        ca   CNTR
        su   UNIT
        ts   CNTR
        sp   MHLOOP            ; JUMP - no return
MHDONE:
        ca   CURMSK
MHRET:  sp   0

; =============================================================
; SUBROUTINE: CWLOOP
; Check whether board CWBD has a winning line.
; Inputs:  CWBD    = board word to check
;          CWLCNT  = number of lines to check (init to 8)
; Output:  WINFLG  = UNIT if win found, ZERO otherwise
; =============================================================
CWLOOP:
        ta   CWRET
        ca   WINTBLADDR
        td   CWLD              ; reload CWLD to point at WINTBL[0]

CWLD:   ca   0                 ; address field = WINTBL+i
        ts   CWMSK

        ca   CWBD
        md   CWMSK
        su   CWMSK             ; zero iff CWBD contains all bits of CWMSK
        dm   0
        cp   CWWON             ; zero -> win!

        ao   CWLD              ; advance to next win mask

        ca   CWLCNT
        su   UNIT
        ts   CWLCNT
        dm   0
        cp   CWDONE            ; zero -> all lines checked, no win
        sp   CWLD              ; JUMP - no return (skip td reload)

CWWON:
        ca   UNIT
        ts   WINFLG

CWDONE:
        sp   CWRET             ; JUMP - no return
CWRET:  sp   0

; =============================================================
; SUBROUTINE: COMPMOV
; Computer picks best move, sets BMOVE.
; Priority: 1) Win  2) Block  3) Center  4) Corner  5) Edge
; =============================================================
COMPMOV:
        ta   CMRET

        ; --- 1. Try to win ---
        ca   BRDX
        ts   TRYBRD
        sp   TRYMOVES          ; CALL - returns
        ca   WINMOV
        dm   0
        cp   CMTRYBLOCK        ; zero -> no win found
        sp   CMRET             ; JUMP - no return
CMTRYBLOCK:

        ; --- 2. Try to block ---
        ca   BRDO
        ts   TRYBRD
        sp   TRYMOVES          ; CALL - returns
        ca   WINMOV
        dm   0
        cp   CMTRYCTR          ; zero -> no block found
        sp   CMRET             ; JUMP - no return
CMTRYCTR:

        ; --- 3. Center ---
        ca   CTR4MSK
        ts   T1
        ca   BRDX
        sd   BRDO
        ts   OCCP
        ca   T1
        md   OCCP
        dm   0
        cp   CTRFREE           ; zero -> center is free
        sp   TRYNEXT1          ; JUMP - no return
CTRFREE:
        ca   CTR4MSK
        ts   BMOVE
        sp   CMRET             ; JUMP - no return

        ; --- 4. Corners ---
TRYNEXT1:
        ca   CORNR0
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNC2            ; zero -> corner 0 free
        sp   CMRET             ; JUMP - no return
TRYNC2:
        ca   CORNR2
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNC6
        sp   CMRET             ; JUMP - no return
TRYNC6:
        ca   CORNR6
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNC8
        sp   CMRET             ; JUMP - no return
TRYNC8:
        ca   CORNR8
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNE1            ; zero -> all corners taken
        sp   CMRET             ; JUMP - no return

        ; --- 5. Edges ---
TRYNE1:
        ca   EDGE1
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNE3
        sp   CMRET             ; JUMP - no return
TRYNE3:
        ca   EDGE3
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNE5
        sp   CMRET             ; JUMP - no return
TRYNE5:
        ca   EDGE5
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   TRYNE7
        sp   CMRET             ; JUMP - no return
TRYNE7:
        ca   EDGE7
        sp   TRYFREE           ; CALL - returns
        dm   0
        cp   CMRET             ; zero -> all edges taken (shouldn't happen)
        sp   CMRET             ; JUMP - no return

CMRET:  sp   0

; =============================================================
; SUBROUTINE: TRYMOVES
; Try each empty square for TRYBRD; find first winning move.
; Input:  TRYBRD = board of side to find winning move for
; Output: WINMOV = one-hot of winning square, or ZERO if none
;         BMOVE  = same as WINMOV if found
; =============================================================
TRYMOVES:
        ta   TMRET
        ca   ZERO
        ts   WINMOV
        ts   SQIDX

TMSQLP:
        ca   SQIDX
        sp   MAKHOT            ; CALL - returns
        ts   BMOVE

        ; Check if square free:
        ca   BRDX
        sd   BRDO
        ts   OCCP
        ca   BMOVE
        md   OCCP
        dm   0
        cp   TMSQFREE          ; zero -> free
        sp   TMNEXT            ; JUMP - no return

TMSQFREE:
        ca   TRYBRD
        sd   BMOVE
        ts   TRYTMP

        ca   ZERO
        ts   WINFLG
        ca   TRYTMP
        ts   CWBD
        ca   EIGHT_VAL
        ts   CWLCNT
        sp   CWLOOP            ; CALL - returns

        ca   WINFLG
        dm   0
        cp   TMNEXT            ; zero -> no win
        sp   TMWIN             ; JUMP - no return

TMNEXT:
        ao   SQIDX
        ca   SQIDX
        su   NINE_VAL
        dm   0
        cp   TMRET             ; zero -> all squares tried
        sp   TMSQLP            ; JUMP - no return

TMWIN:
        ca   BMOVE
        ts   WINMOV
TMRET:  sp   0

; =============================================================
; SUBROUTINE: TRYFREE
; Check if square (one-hot mask in AC) is free.
; Input:  AC = one-hot square mask
; Output: AC = UNIT (positive) if free, BMOVE set
;         AC = -0 (negative) if occupied
; =============================================================
TRYFREE:
        ta   TFRET
        ts   TFMSK
        ca   BRDX
        sd   BRDO
        ts   OCCP
        ca   TFMSK
        md   OCCP
        dm   0
        cp   TFFREE            ; zero -> free
        ca   NEGZ              ; occupied: return -0
        sp   TFRET             ; JUMP - no return
TFFREE:
        ca   TFMSK
        ts   BMOVE
        ca   UNIT
TFRET:  sp   0

; =============================================================
; SUBROUTINE: PRMBOARD
; Print current board state on Flexowriter.
; =============================================================
PRMBOARD:
        ta   PBRET
        ca   ZERO
        ts   SQIDX

PBLOOP:
        ca   SQIDX
        sp   MAKHOT            ; CALL - returns
        ts   TBIT

        ca   TBIT
        md   BRDX
        dm   0
        cp   TRYO              ; zero -> not X
        sp   PBPX              ; JUMP - no return
TRYO:
        ca   TBIT
        md   BRDO
        dm   0
        cp   TRYEMPTY          ; zero -> not O
        sp   PBPO              ; JUMP - no return
TRYEMPTY:
        si   0o225
        ca   CHRDOT
        rc 0
        sp   PBSEP             ; JUMP - no return

PBPX:
        si   0o225
        ca   CHRX
        rc 0
        sp   PBSEP             ; JUMP - no return

PBPO:
        si   0o225
        ca   CHRO
        rc 0

PBSEP:
        ao   SQIDX

        ca   SQIDX
        su   THREE_VAL
        dm   0
        cp   PBROWSEP          ; zero -> row separator after row 0

        ca   SQIDX
        su   SIX_VAL
        dm   0
        cp   PBROWSEP          ; zero -> row separator after row 1

        ca   SQIDX
        su   NINE_VAL
        dm   0
        cp   PBEND             ; zero -> done

        si   0o225
        ca   CHRBAR
        rc 0
        sp   PBLOOP            ; JUMP - no return

PBROWSEP:
        si   0o225
        ca   CHRNL
        rc 0
        sp   PRSEP             ; CALL - returns
        sp   PBLOOP            ; JUMP - no return

PBEND:
        si   0o225
        ca   CHRNL
        rc 0
PBRET:  sp   0

; =============================================================
; SUBROUTINE: PRSEP
; Print "-----\n" row separator.
; =============================================================
PRSEP:
        ta   PSRET
        si   0o225
        ca   CHRDSH
        rc 0
        si   0o225
        ca   CHRDSH
        rc 0
        si   0o225
        ca   CHRDSH
        rc 0
        si   0o225
        ca   CHRDSH
        rc 0
        si   0o225
        ca   CHRDSH
        rc 0
        si   0o225
        ca   CHRNL
        rc 0
PSRET:  sp   0

; =============================================================
; SUBROUTINE: PRBANNER
; =============================================================
PRBANNER:
        ta   PBNRET
        sp   PRSTR             ; CALL - returns
        .word BNNSTR
PBNRET: sp   0

; =============================================================
; SUBROUTINE: PRMPRMT
; =============================================================
PRMPRMT:
        ta   PPRET
        sp   PRSTR             ; CALL - returns
        .word PRMSTR
PPRET:  sp   0

; =============================================================
; SUBROUTINE: PRSTR
; Print string of Flexo codes terminated by -1.
; String address passed in word following sp PRSTR call.
; Characters in lower 6 bits; clc shifts them to top 6.
; =============================================================
PRSTR:
        ta   PRRET
        ca   PRRET
        td   PRaddr
PRaddr: ca   0
        td   PRLOOP
        ao   PRRET

PRLOOP: ca   0
        cp   PREND             ; negative (-1) -> done
        clc  0o12
        si   0o225
        rc 0
        ao   PRLOOP
        sp   PRLOOP            ; JUMP - no return
PREND:
        sp   PRRET             ; JUMP - no return
PRRET:  sp   0

; =============================================================
; SUBROUTINE: PRMCOMPMOV
; Print "COMPUTER PLAYS SQUARE N\n"
; =============================================================
PRMCOMPMOV:
        ta   PCMRET
        sp   PRSTR             ; CALL - returns
        .word CMVSTR

        ca   ZERO
        ts   SQIDX
PCMLP:
        ca   SQIDX
        sp   MAKHOT            ; CALL - returns
        su   BMOVE
        dm   0
        cp   PCMFND            ; zero -> found matching square
        ao   SQIDX
        sp   PCMLP             ; JUMP - no return

PCMFND:
        ca   SQIDX
        ad   flexo_num_tbl_ptr
        td   char_conv1
char_conv1: ca 0
        
;               ad   FCHAR1
        clc  0o12
        si   0o225
        rc 0
        si   0o225
        ca   CHRNL
        rc 0
PCMRET: sp   0

; =============================================================
; MESSAGE SUBROUTINES
; =============================================================
PRMHWIN:
        ta   PHWRET
        sp   PRSTR             ; CALL - returns
        .word HWSTR
PHWRET: sp   0

PRMCWIN:
        ta   PCWRET
        sp   PRSTR             ; CALL - returns
        .word CWSTR
PCWRET: sp   0

PRMDRAW:
        ta   PDRET
        sp   PRSTR             ; CALL - returns
        .word DWSTR
PDRET:  sp   0

PRMBADMOV:
        ta   PBMRET
        sp   PRSTR             ; CALL - returns
        .word BDSTR
PBMRET: sp   0

PRMSQTKN:
        ta   PSTRET
        sp   PRSTR             ; CALL - returns
        .word STSTR
PSTRET: sp   0



; =============================================================
; DATA AREA
; =============================================================
        .org  0o2000

BRDX:   .word 0o0
BRDO:   .word 0o0
TURN:   .word 0o0
WINFLG: .word 0o0
BMOVE:  .word 0o0
SQIDX:  .word 0o0
CNTR:   .word 0o0              ; MAKHOT loop counter
CWBD:   .word 0o0
CWMSK:  .word 0o0
CWLCNT: .word 0o0
WINMOV: .word 0o0
TRYBRD: .word 0o0
TRYTMP: .word 0o0
OCCP:   .word 0o0
TFMSK:  .word 0o0
CURMSK: .word 0o0              ; MAKHOT shifted mask
TBIT:   .word 0o0
T1:     .word 0o0
T2:     .word 0o0
T3:     .word 0o0
PRPTR:  .word 0o0

; =============================================================
; CONSTANTS
; =============================================================
ZERO:       .word 0o0
ONE:        .word 0o1
NEGZ:       .word 0o177777
UNIT:       .word 0o00001
FCHAR1:     .word 0o000100     ; Flexo code for '1' (check Table 1)
NINE_VAL:   .word 0o000011
EIGHT_VAL:  .word 0o000010
THREE_VAL:  .word 0o000003
SIX_VAL:    .word 0o000006

SQ0MASK:    .word 0o001000
CTR4MSK:    .word 0o000040
CORNR0:     .word 0o001000
CORNR2:     .word 0o000200
CORNR6:     .word 0o000010
CORNR8:     .word 0o000002
EDGE1:      .word 0o000400
EDGE3:      .word 0o000100
EDGE5:      .word 0o000020
EDGE7:      .word 0o000004

CHRDOT:     .flexh "."
CHRX:       .flexh "x"
CHRO:       .flexh "o"
CHRBAR:     .flexh "|"
CHRNL:      .flexh "\n"
CHRDSH:     .flexh "-"

; =============================================================
; WIN-LINE TABLE
; =============================================================
WINTBL:
        .word 0o001600         ; row 0: sq0|sq1|sq2
        .word 0o000160         ; row 1: sq3|sq4|sq5
        .word 0o000016         ; row 2: sq6|sq7|sq8
        .word 0o001110         ; col 0: sq0|sq3|sq6
        .word 0o000444         ; col 1: sq1|sq4|sq7
        .word 0o000222         ; col 2: sq2|sq5|sq8
        .word 0o001042         ; diag0: sq0|sq4|sq8
        .word 0o000250         ; diag1: sq2|sq4|sq6

WINTBLADDR: .word WINTBL

; =============================================================
; STRING DATA
; =============================================================
BNNSTR: .flexl "TIC TAC TOE\n", -1
PRMSTR: .flexl "YOUR MOVE (1-9): \n", -1
HWSTR:  .flexl "YOU WIN\n", -1
CWSTR:  .flexl "COMPUTER WINS\n", -1
DWSTR:  .flexl "DRAW.\n", -1
BDSTR:  .flexl "INVALID - TRY AGAIN\n", -1
STSTR:  .flexl "SQUARE TAKEN - TRY AGAIN\n", -1
CMVSTR: .flexl "  COMPUTER PLAYS SQUARE ", -1

PLOSTR: .flexl "Player O"


; 
