@0120:000125     autoclick_tab_lastp: .word autoclick_tab_last ; @@ReadBy a0041
                       autoclick_tab:
@0121:000000                          .word 0                  ; unused cell at offset -0
@0122:000010                          .word 8                  ; fourth move
@0123:000003                          .word 3                  ; third move
@0124:000001                          .word 1                  ; second move; play cell 1
                  autoclick_tab_last:
@0125:000004                          .word 4                  ; first move; play cell 4 (center)  (top left is cell zero)

